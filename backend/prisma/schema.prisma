generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String
  name           String?
  avatar         String?
  college        String?
  degree         String?
  gradYear       Int?
  preferredRoles String?       // Comma separated
  techStack      String?       // Comma separated
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  applications   Application[]
  resumes        Resume[]
  notes          Note[]
  goals          Goal[]
}

model Application {
  id           String    @id @default(uuid())
  company      String
  role         String
  status       String    @default("WISHLIST")
  package      String?
  location     String?
  applyDate    DateTime?
  deadline     DateTime?
  tags         String?   // Comma separated
  priority     String?
  notes        String?
  userId       String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id])
  interviews   Interview[]
}

model Interview {
  id            String      @id @default(uuid())
  applicationId String
  date          DateTime
  round         String
  interviewer   String?
  questions     String?     // Comma separated
  feedback      String?
  result        String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  application   Application @relation(fields: [applicationId], references: [id])
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   String   // Markdown content
  company   String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

model Resume {
  id          String   @id @default(uuid())
  title       String
  url         String
  atsScore    Int?
  missingKeys String?  // Comma separated
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model Goal {
  id          String   @id @default(uuid())
  title       String
  targetValue Int
  currentVal  Int      @default(0)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}
